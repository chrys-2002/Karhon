// ─────────────────────────────────────────────────────────────
// Schéma Prisma — KARHON Assurances
// Décrit toutes les tables de la base PostgreSQL.
// Source : src/types/index.ts (modèle métier).
//
// Commandes utiles :
//   npx prisma migrate dev --name init   → crée/maj la base
//   npx prisma generate                  → régénère le client
//   npx prisma studio                    → interface visuelle de la base
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Énumérations (valeurs fermées) ───────────────────────────

enum Role {
  client
  agent   // gestionnaire : traite devis, sinistres, contrats ; suppression = archivage
  gerant  // dirigeant : voit tout (y compris archives + journal), peut restaurer/purger
  admin   // ancien rôle (compatibilité) — traité comme gérant
}

// Rôles du PERSONNEL (table Admin), séparés des clients pour plus de
// sécurité et de clarté.
enum RoleAdmin {
  agent
  gerant
}

enum StatutDevis {
  en_attente
  en_cours
  envoye
  choisi      // le client a choisi une offre, en attente de paiement
  paye        // paiement confirmé par le rédacteur, à valider
  accepte
  refuse
}

enum StatutContrat {
  actif
  suspendu
  resilie
}

// Segment d'une souscription :
//   particulier   → usage personnel d'un particulier
//   professionnel → flotte / pack auto d'une entreprise
//   transport     → transport professionnel (taxi, marchandises, VTC, gbaka…)
enum SegmentContrat {
  particulier
  professionnel
  transport
}

enum StatutSinistre {
  declare
  en_cours
  indemnise
  refuse
}

enum StatutRendezVous {
  en_attente
  confirme
  annule
  termine
}

enum TypeProduit {
  IARD
  VIE
}

// ── Tables ───────────────────────────────────────────────────

model User {
  id              String       @id @default(cuid())
  nom             String
  prenom          String
  email           String       @unique
  telephone       String?      @unique // unique : sert d'identifiant de connexion ; null pour les comptes Google sans numéro
  adresse         String?
  motDePasse      String?      // haché (bcrypt) ; null pour les comptes Google
  googleId        String?      @unique // identifiant Google si connexion via Google
  avatar          String?      // photo de profil Google
  role            Role         @default(client)
  dateInscription DateTime     @default(now())

  // Réinitialisation du mot de passe (on stocke un HASH du jeton, jamais le jeton brut).
  resetToken       String?
  resetTokenExpiry DateTime?

  // Relations : un utilisateur possède plusieurs devis/contrats/rdv
  devis           Devis[]
  contrats        Contrat[]
  rendezVous      RendezVous[]
  sinistres       Sinistre[]
  messages        Message[]

  @@map("users")
}

// Personnel du back-office (agents + gérant), séparé des clients.
// Un seul champ `role` distingue agent et gérant.
model Admin {
  id           String    @id @default(cuid())
  nom          String
  prenom       String
  email        String    @unique
  motDePasse   String    // haché (bcrypt)
  role         RoleAdmin @default(agent)
  dateCreation DateTime  @default(now())

  @@map("admins")
}

model Produit {
  id          String      @id @default(cuid())
  nom         String
  type        TypeProduit
  categorie   String
  description String
  garanties   String[]    // tableau natif PostgreSQL
  imageUrl    String?

  devis       Devis[]
  contrats    Contrat[]

  @@map("produits")
}

model Devis {
  id            String      @id @default(cuid())
  dateCreation  DateTime    @default(now())
  statut        StatutDevis @default(en_attente)
  segment       SegmentContrat @default(particulier) // catégorie choisie par le client (auto → portée au contrat)
  montantEstime    Float?
  description      String
  documents        String[]
  reponses         Json?     // réponses au questionnaire spécifique du produit
  telephoneContact String?   // numéro où le client souhaite être joint (relance)

  // Paiement de l'offre choisie par le client.
  modePaiement     String?   // "cheque" | "wave" | "orange_money"
  montantAPayer    Float?    // prime/montant indiqué par le rédacteur après le choix du client
  lienPaiement     String?   // lien de paiement (Wave / Orange Money) envoyé par le rédacteur

  // Suivi des relances par le courtier.
  derniereRelance DateTime?
  nombreRelances  Int       @default(0)

  // Suppression douce (archivage) — traçabilité des agents.
  supprime    Boolean   @default(false)
  supprimePar String?   // email de l'agent ayant archivé
  supprimeLe  DateTime?

  // Clés étrangères
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  produitId     String
  produit       Produit     @relation(fields: [produitId], references: [id])

  propositions  Proposition[]

  @@map("devis")
}

// Proposition (cotation) d'une compagnie partenaire, rattachée à un devis.
// L'agent en envoie une par compagnie ; le client en choisit une.
model Proposition {
  id         String    @id @default(cuid())
  compagnie  String    // compagnie partenaire
  documents  String[]  // fiche(s) PDF au format "Libellé|url"
  prime      Float?    // prime proposée (optionnel)
  message    String?   // note de l'agent
  choisie    Boolean   @default(false)
  vueClient  Boolean   @default(false)  // true dès que le client a consulté cette offre (repère « nouveau »)
  dateEnvoi  DateTime  @default(now())
  dateChoix  DateTime?

  devisId    String
  devis      Devis     @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@index([devisId, vueClient])
  @@map("propositions")
}

model Contrat {
  id            String        @id @default(cuid())
  numeroContrat String        @unique
  dateDebut     DateTime
  dateFin       DateTime
  dureeMois     Int           @default(12) // durée souscrite : 1, 2, 3, 6 ou 12 mois
  primeAnnuelle Float
  segment       SegmentContrat @default(particulier) // particulier (perso) ou professionnel (flotte)
  compagnie     String?       // compagnie partenaire avec qui le contrat est conclu
  telephoneContact String?    // numéro de contact du client (repris du devis, pour les relances)
  statut        StatutContrat @default(actif)
  options       String[]

  // Suivi des relances de renouvellement (avant le terme).
  derniereRelance DateTime?
  nombreRelances  Int        @default(0)

  // Suppression douce (archivage) — traçabilité des agents.
  supprime    Boolean   @default(false)
  supprimePar String?
  supprimeLe  DateTime?

  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  produitId     String
  produit       Produit       @relation(fields: [produitId], references: [id])

  sinistres     Sinistre[]

  @@map("contrats")
}

model Sinistre {
  id               String         @id @default(cuid())
  dateSurvenance   DateTime
  heureSurvenance  String?        // heure approximative du sinistre (ex. "14:30")
  lieu             String?        // lieu du sinistre
  dateDeclaration  DateTime       @default(now())
  description      String
  typeAssurance    String?        // type d'assurance choisi par le client (auto, habitation…)
  montantEstime    Float?         // estimation déclarée par le client
  montantIndemnise Float?         // montant réellement indemnisé (renseigné par le courtier)
  statut           StatutSinistre @default(declare)
  documents        String[]

  // Suivi des relances par le courtier.
  derniereRelance  DateTime?
  nombreRelances   Int            @default(0)

  // Suppression douce (archivage) — traçabilité des agents.
  supprime         Boolean        @default(false)
  supprimePar      String?
  supprimeLe       DateTime?

  // Le sinistre est rattaché au client connecté qui le déclare.
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Lien facultatif vers un contrat précis (renseigné plus tard par le courtier).
  contratId        String?
  contrat          Contrat?       @relation(fields: [contratId], references: [id], onDelete: SetNull)

  @@map("sinistres")
}

model RendezVous {
  id        String           @id @default(cuid())
  dateHeure DateTime
  statut    StatutRendezVous @default(en_attente)
  motif     String
  notes     String?

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rendez_vous")
}

// Notifications in-app : informent l'agent (nouvelle demande/déclaration)
// et le client (réponse, proposition, changement de statut).
//   • cible = "agent"  → visible par tout le personnel (userId null).
//   • cible = "client" → destinée à un client précis (userId = son id).
model Notification {
  id        String   @id @default(cuid())
  cible     String   // "agent" | "client"
  userId    String?  // client destinataire (null pour les notifs agent)
  type      String   // "devis" | "sinistre" | "rendezvous" | "proposition" | "statut" | "choix"
  titre     String
  message   String
  lien      String?  // ex. "/admin" ou "/client/dashboard"
  lu        Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([cible, userId, lu])
  @@index([createdAt])
  @@map("notifications")
}

// Messagerie client ↔ rédacteur. Une conversation par client (userId).
//   expediteur = "client" (écrit par le client) ou "staff" (écrit par un rédacteur).
//   piecesJointes : documents corrigés renvoyés par le client, ou pièces jointes.
//   contexte / contexteId : rattachement facultatif à un dossier (devis, sinistre).
model Message {
  id            String   @id @default(cuid())
  userId        String   // le CLIENT concerné par la conversation
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expediteur    String   // "client" | "staff"
  auteurEmail   String?  // email du rédacteur (si staff)
  contenu       String
  piecesJointes String[] // "Libellé|url" (ex. document corrigé)
  contexte      String?  // "devis" | "sinistre" (facultatif)
  contexteId    String?
  lu            Boolean  @default(false) // lu par le destinataire
  archive       Boolean  @default(false) // message archivé (masqué des conversations)
  archiveLe     DateTime?
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([expediteur, lu])
  @@index([archive])
  @@map("messages")
}

// Journal d'audit : trace les actions sensibles (archivage, restauration,
// purge). Permet au gérant de savoir QUI a fait QUOI et QUAND.
model JournalAudit {
  id          String   @id @default(cuid())
  action      String   // "archivage" | "restauration" | "purge"
  entite      String   // "devis" | "sinistre" | "contrat"
  entiteId    String
  resume      String?  // description lisible (ex. "Devis Assurance Auto — Jean Koffi")
  auteurEmail String   // qui a agi
  auteurNom   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([entite])
  @@index([auteurEmail])
  @@map("journal_audit")
}
