// ─────────────────────────────────────────────────────────────
// Schéma Prisma — KARHON Assurances
// Décrit toutes les tables de la base PostgreSQL.
// Source : src/types/index.ts (modèle métier).
//
// Commandes utiles :
//   npx prisma migrate dev --name init   → crée/maj la base
//   npx prisma generate                  → régénère le client
//   npx prisma studio                    → interface visuelle de la base
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Énumérations (valeurs fermées) ───────────────────────────

enum Role {
  client
  agent   // gestionnaire : traite devis, sinistres, contrats ; suppression = archivage
  gerant  // dirigeant : voit tout (y compris archives + journal), peut restaurer/purger
  admin   // ancien rôle (compatibilité) — traité comme gérant
}

enum StatutDevis {
  en_attente
  en_cours
  envoye
  accepte
  refuse
}

enum StatutContrat {
  actif
  suspendu
  resilie
}

enum StatutSinistre {
  declare
  en_cours
  indemnise
  refuse
}

enum StatutRendezVous {
  en_attente
  confirme
  annule
  termine
}

enum TypeProduit {
  IARD
  VIE
}

// ── Tables ───────────────────────────────────────────────────

model User {
  id              String       @id @default(cuid())
  nom             String
  prenom          String
  email           String       @unique
  telephone       String
  adresse         String?
  motDePasse      String       // toujours haché (bcrypt), jamais en clair
  role            Role         @default(client)
  dateInscription DateTime     @default(now())

  // Relations : un utilisateur possède plusieurs devis/contrats/rdv
  devis           Devis[]
  contrats        Contrat[]
  rendezVous      RendezVous[]
  sinistres       Sinistre[]

  @@map("users")
}

model Produit {
  id          String      @id @default(cuid())
  nom         String
  type        TypeProduit
  categorie   String
  description String
  garanties   String[]    // tableau natif PostgreSQL
  imageUrl    String?

  devis       Devis[]
  contrats    Contrat[]

  @@map("produits")
}

model Devis {
  id            String      @id @default(cuid())
  dateCreation  DateTime    @default(now())
  statut        StatutDevis @default(en_attente)
  montantEstime Float?
  description   String
  documents     String[]

  // Suivi des relances par le courtier.
  derniereRelance DateTime?
  nombreRelances  Int       @default(0)

  // Suppression douce (archivage) — traçabilité des agents.
  supprime    Boolean   @default(false)
  supprimePar String?   // email de l'agent ayant archivé
  supprimeLe  DateTime?

  // Clés étrangères
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  produitId     String
  produit       Produit     @relation(fields: [produitId], references: [id])

  @@map("devis")
}

model Contrat {
  id            String        @id @default(cuid())
  numeroContrat String        @unique
  dateDebut     DateTime
  dateFin       DateTime
  dureeMois     Int           @default(12) // durée souscrite : 1, 2, 3, 6 ou 12 mois
  primeAnnuelle Float
  statut        StatutContrat @default(actif)
  options       String[]

  // Suivi des relances de renouvellement (avant le terme).
  derniereRelance DateTime?
  nombreRelances  Int        @default(0)

  // Suppression douce (archivage) — traçabilité des agents.
  supprime    Boolean   @default(false)
  supprimePar String?
  supprimeLe  DateTime?

  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  produitId     String
  produit       Produit       @relation(fields: [produitId], references: [id])

  sinistres     Sinistre[]

  @@map("contrats")
}

model Sinistre {
  id               String         @id @default(cuid())
  dateSurvenance   DateTime
  heureSurvenance  String?        // heure approximative du sinistre (ex. "14:30")
  lieu             String?        // lieu du sinistre
  dateDeclaration  DateTime       @default(now())
  description      String
  typeAssurance    String?        // type d'assurance choisi par le client (auto, habitation…)
  montantEstime    Float?         // estimation déclarée par le client
  montantIndemnise Float?         // montant réellement indemnisé (renseigné par le courtier)
  statut           StatutSinistre @default(declare)
  documents        String[]

  // Suivi des relances par le courtier.
  derniereRelance  DateTime?
  nombreRelances   Int            @default(0)

  // Suppression douce (archivage) — traçabilité des agents.
  supprime         Boolean        @default(false)
  supprimePar      String?
  supprimeLe       DateTime?

  // Le sinistre est rattaché au client connecté qui le déclare.
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Lien facultatif vers un contrat précis (renseigné plus tard par le courtier).
  contratId        String?
  contrat          Contrat?       @relation(fields: [contratId], references: [id], onDelete: SetNull)

  @@map("sinistres")
}

model RendezVous {
  id        String           @id @default(cuid())
  dateHeure DateTime
  statut    StatutRendezVous @default(en_attente)
  motif     String
  notes     String?

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rendez_vous")
}

// Journal d'audit : trace les actions sensibles (archivage, restauration,
// purge). Permet au gérant de savoir QUI a fait QUOI et QUAND.
model JournalAudit {
  id          String   @id @default(cuid())
  action      String   // "archivage" | "restauration" | "purge"
  entite      String   // "devis" | "sinistre" | "contrat"
  entiteId    String
  resume      String?  // description lisible (ex. "Devis Assurance Auto — Jean Koffi")
  auteurEmail String   // qui a agi
  auteurNom   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("journal_audit")
}
