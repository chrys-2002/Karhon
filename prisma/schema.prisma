// ─────────────────────────────────────────────────────────────
// Schéma Prisma — KARHON Assurances
// Décrit toutes les tables de la base PostgreSQL.
// Source : src/types/index.ts (modèle métier).
//
// Commandes utiles :
//   npx prisma migrate dev --name init   → crée/maj la base
//   npx prisma generate                  → régénère le client
//   npx prisma studio                    → interface visuelle de la base
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Énumérations (valeurs fermées) ───────────────────────────

enum Role {
  client
  admin
}

enum StatutDevis {
  en_attente
  en_cours
  envoye
  accepte
  refuse
}

enum StatutContrat {
  actif
  suspendu
  resilie
}

enum StatutSinistre {
  declare
  en_cours
  indemnise
  refuse
}

enum StatutRendezVous {
  en_attente
  confirme
  annule
  termine
}

enum TypeProduit {
  IARD
  VIE
}

// ── Tables ───────────────────────────────────────────────────

model User {
  id              String       @id @default(cuid())
  nom             String
  prenom          String
  email           String       @unique
  telephone       String
  adresse         String?
  motDePasse      String       // toujours haché (bcrypt), jamais en clair
  role            Role         @default(client)
  dateInscription DateTime     @default(now())

  // Relations : un utilisateur possède plusieurs devis/contrats/rdv
  devis           Devis[]
  contrats        Contrat[]
  rendezVous      RendezVous[]

  @@map("users")
}

model Produit {
  id          String      @id @default(cuid())
  nom         String
  type        TypeProduit
  categorie   String
  description String
  garanties   String[]    // tableau natif PostgreSQL
  imageUrl    String?

  devis       Devis[]
  contrats    Contrat[]

  @@map("produits")
}

model Devis {
  id            String      @id @default(cuid())
  dateCreation  DateTime    @default(now())
  statut        StatutDevis @default(en_attente)
  montantEstime Float?
  description   String
  documents     String[]

  // Clés étrangères
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  produitId     String
  produit       Produit     @relation(fields: [produitId], references: [id])

  @@map("devis")
}

model Contrat {
  id            String        @id @default(cuid())
  numeroContrat String        @unique
  dateDebut     DateTime
  dateFin       DateTime
  primeAnnuelle Float
  statut        StatutContrat @default(actif)
  options       String[]

  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  produitId     String
  produit       Produit       @relation(fields: [produitId], references: [id])

  sinistres     Sinistre[]

  @@map("contrats")
}

model Sinistre {
  id               String         @id @default(cuid())
  dateSurvenance   DateTime
  dateDeclaration  DateTime       @default(now())
  description      String
  montantIndemnise Float?
  statut           StatutSinistre @default(declare)
  documents        String[]

  contratId        String
  contrat          Contrat        @relation(fields: [contratId], references: [id], onDelete: Cascade)

  @@map("sinistres")
}

model RendezVous {
  id        String           @id @default(cuid())
  dateHeure DateTime
  statut    StatutRendezVous @default(en_attente)
  motif     String
  notes     String?

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rendez_vous")
}
